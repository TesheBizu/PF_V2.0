MONGO_URI=mongodb://localhost:27017/pf_v2
JWT_SECRET=your_jwt_secret_here
PORT=5000
PUBLIC_CLIENT_URL=http://localhost:5173
ADMIN_CLIENT_URL=http://localhost:5174
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_password
EMAIL_SERVICE=gmail

# GitHub contributions graph (public portfolio activity)
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_USERNAME=your_github_username

# Single-admin auth (run `node scripts/seedAdmin.js` once after setting these)
ADMIN_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_me_after_first_login

# Google OAuth (single-admin, email must match ADMIN_EMAIL exactly)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
